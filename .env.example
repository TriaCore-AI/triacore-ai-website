# Resend nieuwsbrief-integratie
# Kopieer dit bestand naar .env (lokaal) of zet deze waarden in het Netlify-dashboard
# (Site settings -> Environment variables). Zet hier NOOIT echte sleutels in een commit.

# API-key uit het Resend-dashboard (Settings -> API Keys)
RESEND_API_KEY=

# ID van de Audience (nieuwsbrieflijst) in Resend (Audiences -> jouw lijst)
RESEND_AUDIENCE_ID=

# Afzender van de welkomstmail. Domein moet GEVERIFIEERD zijn in Resend.
# app.triacore.be is al geverifieerd (gratis tier = 1 domein) -> hergebruik dat.
# Lokaal deel (nieuws) mag je vrij kiezen; er hoeft geen mailbox voor te bestaan.
# Formaat: "Naam <adres@domein>"
NEWSLETTER_FROM=TriaCore AI <nieuws@app.triacore.be>

# Optioneel: adres waarnaar antwoorden op de welkomstmail gaan (je echte inbox).
NEWSLETTER_REPLY_TO=info@triacore.be
